    {
      "id": "concept_private_route",
      "label": "Private/Protected Route Pattern",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 5",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: Protects authenticated pages by checking auth state (auth?.user) before rendering children; redirects to /login otherwise. All providers should wrap PrivateRoutes."
    },
    {
      "id": "concept_auth_context",
      "label": "AuthContext and AuthContextType",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 158",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: createContext must be typed with AuthContextType|null so TypeScript can enforce correct property access (authToken, user) across all consumers."
    },
    {
      "id": "concept_token_storage",
      "label": "Token Storage Strategy (Access + Refresh Token)",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 105",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: Best practice is access token in memory (React state/Zustand) and refresh token in HttpOnly cookie. localStorage is convenient for learning but vulnerable to XSS."
    },
    {
      "id": "concept_axios_interceptor",
      "label": "Axios Interceptor for JWT Auto-Refresh (useAxios hook)",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 262",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: Request interceptor attaches Bearer token; response interceptor catches 401 errors, calls refresh-token endpoint, updates auth state, and retries original request — keeping user logged in across page sessions."
    },
    {
      "id": "concept_lazy_initializer",
      "label": "Lazy Initializer Function for useState",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 354",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: Pass a function to useState instead of a value to defer expensive one-time computations (e.g., JSON.parse from localStorage) until first mount, avoiding repeated cost on re-renders."
    },
    {
      "id": "concept_profile_state_pattern",
      "label": "Profile State Pattern: Reducer + Context + Hook",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 375",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: Auth context should only store authentication data. Profile data belongs in a separate ProfileContext + ProfileReducer pipeline: actions => reducers => context => providers => hooks."
    },
    {
      "id": "concept_file_upload_useref",
      "label": "File Upload via useRef (Custom Button Trigger)",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 472",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: File inputs cannot be controlled with useState for security reasons; useRef gives direct DOM access to trigger the file picker and read selected files. FormData is required for multipart/form-data when sending files alongside text."
    },
    {
      "id": "concept_like_reducer",
      "label": "Like Feature via POST_LIKED Reducer Action",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 619",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: Local useState for likes causes sync issues when a post appears in multiple places. Using a shared reducer (POST_LIKED) ensures all components rendering the same post reflect the same like state. PATCH request is used because only partial data changes."
    },
    {
      "id": "concept_comment_enter_key",
      "label": "Comment Submit via Enter Key (onKeyDown)",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 700",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: When no submit button is present, use onKeyDown with keyCode===13 to submit comment data to the API via PATCH request."
    },
    {
      "id": "concept_post_create_reducer",
      "label": "Post Creation via Reducer (POST_CREATED action)",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 746",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: New posts are prepended to the posts array in the reducer ([action.data, ...state.posts]) so newest content appears first without additional sorting."
    },
    {
      "id": "concept_delete_comment",
      "label": "Delete Comment Feature (POST_COMMENT_DELETED action)",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 843",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: Only show delete button when comment.author.id === auth.user.id. Dispatch POST_COMMENT_DELETED after successful API DELETE to filter comment from the shared posts state."
    },
    {
      "id": "concept_usedebugvalue",
      "label": "useDebugValue Performance Optimization",
      "file_type": "rationale",
      "source_file": "Facehook Project part 2.txt",
      "source_location": "line 223",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "rationale: useDebugValue is purely for React DevTools visibility. The formatter function (second argument) runs lazily — only when DevTools is open — avoiding unnecessary computation on every render."
    }
  ],

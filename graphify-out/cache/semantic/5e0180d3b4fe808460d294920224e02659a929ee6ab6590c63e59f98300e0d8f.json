on": null, "weight": 1.0}], "hyperedges": [{"id": "post_crud_reducers", "label": "Post CRUD Operations via Reducer Actions", "nodes": ["concept_post_create_reducer", "concept_like_reducer", "concept_delete_comment"], "relation": "implement", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "Facehook Project part 2.txt"}, {"id": "auth_token_flow", "label": "Authentication Token Management Flow", "nodes": ["concept_auth_context", "concept_token_storage", "concept_axios_interceptor"], "relation": "participate_in", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "Facehook Project part 2.txt"}]}